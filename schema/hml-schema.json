{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://honeygui.io/schemas/hml.json",
  "title": "HoneyGUI HML Schema",
  "description": "JSON Schema for validating HoneyGUI HML (XML-based UI markup) structure",
  "version": "0.1.0",
  
  "type": "object",
  "required": ["hml"],
  "properties": {
    "hml": {
      "$ref": "#/definitions/hml"
    }
  },
  
  "definitions": {
    "hml": {
      "type": "object",
      "properties": {
        "meta": {
          "$ref": "#/definitions/meta"
        },
        "views": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/hg_view"
          },
          "description": "At least one view element is required"
        }
      },
      "required": ["views"],
      "additionalProperties": false
    },
    
    "meta": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Screen/page title"
        },
        "description": {
          "type": "string",
          "description": "Screen description"
        },
        "project": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "appId": {
              "type": "string"
            },
            "resolution": {
              "type": "string",
              "pattern": "^\\d+[xX]\\d+$",
              "description": "Screen resolution, e.g., '454x454' or '368x448'"
            },
            "pixelMode": {
              "type": "string",
              "enum": ["RGB565", "RGB888", "ARGB8888"],
              "description": "Pixel format"
            }
          }
        }
      }
    },
    
    "component_base": {
      "type": "object",
      "required": ["id", "name", "x", "y", "w", "h"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Unique identifier, must start with lowercase letter, alphanumeric + underscore"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Display name for designer UI"
        },
        "x": {
          "type": "number",
          "minimum": 0,
          "description": "X position in pixels"
        },
        "y": {
          "type": "number",
          "minimum": 0,
          "description": "Y position in pixels"
        },
        "w": {
          "type": "number",
          "minimum": 0,
          "description": "Width in pixels"
        },
        "h": {
          "type": "number",
          "minimum": 0,
          "description": "Height in pixels"
        }
      }
    },
    
    "hg_button": {
      "allOf": [
        {
          "$ref": "#/definitions/component_base"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "pattern": "^btn_[a-z0-9_]+$",
              "description": "Button ID must start with 'btn_'"
            },
            "w": {
              "minimum": 44,
              "description": "Button width must be at least 44px for touch targets"
            },
            "h": {
              "minimum": 44,
              "description": "Button height must be at least 44px for touch targets"
            },
            "text": {
              "type": "string",
              "description": "Button label text (optional)"
            },
            "src": {
              "type": "string",
              "pattern": "^assets/.*\\.bin$",
              "description": "Image path, must be .bin file in assets/ directory"
            },
            "onClick": {
              "type": "string",
              "description": "Click event handler function name"
            },
            "backgroundColor": {
              "type": "string",
              "pattern": "^#([0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})$",
              "description": "Background color in hex format (#RRGGBB or #AARRGGBB)"
            },
            "fontSize": {
              "type": "number",
              "minimum": 12,
              "description": "Font size for button text"
            },
            "color": {
              "type": "string",
              "pattern": "^#([0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})$",
              "description": "Text color in hex format"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    
    "hg_label": {
      "allOf": [
        {
          "$ref": "#/definitions/component_base"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "pattern": "^lbl_[a-z0-9_]+$",
              "description": "Label ID must start with 'lbl_'"
            },
            "text": {
              "type": "string",
              "description": "Static text content"
            },
            "fontSize": {
              "type": "number",
              "minimum": 16,
              "default": 16,
              "description": "Font size must be at least 16px for readability"
            },
            "color": {
              "type": "string",
              "pattern": "^#([0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})$",
              "description": "Text color in hex format (#RRGGBB or #AARRGGBB)"
            },
            "backgroundColor": {
              "type": "string",
              "pattern": "^#([0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})$",
              "description": "Background color in hex format"
            },
            "fontFamily": {
              "type": "string",
              "pattern": "^assets/fonts/.*\\.(ttf|otf|bin)$",
              "description": "Font file path in assets/fonts/"
            },
            "textAlign": {
              "type": "string",
              "enum": ["left", "center", "right"],
              "default": "left",
              "description": "Text alignment"
            },
            "timeFormat": {
              "type": "string",
              "pattern": "^(HH|MM|SS|YYYY|DD).*$",
              "description": "Time format string, e.g., 'HH:MM:SS', 'YYYY-MM-DD'"
            },
            "isTimerLabel": {
              "type": "boolean",
              "description": "Enable timer mode (stopwatch/countdown)"
            },
            "timerType": {
              "type": "string",
              "enum": ["stopwatch", "countdown"],
              "description": "Timer type"
            },
            "timerFormat": {
              "type": "string",
              "enum": ["HH:MM:SS", "MM:SS", "MM:SS:MS", "SS"],
              "description": "Timer display format"
            },
            "timerInitialValue": {
              "type": "number",
              "minimum": 0,
              "description": "Initial value in milliseconds"
            },
            "timerAutoStart": {
              "type": "boolean",
              "default": true,
              "description": "Auto-start timer on load"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    
    "hg_image": {
      "allOf": [
        {
          "$ref": "#/definitions/component_base"
        },
        {
          "type": "object",
          "required": ["src"],
          "properties": {
            "id": {
              "pattern": "^img_[a-z0-9_]+$",
              "description": "Image ID must start with 'img_'"
            },
            "src": {
              "type": "string",
              "pattern": "^assets/.*\\.bin$",
              "description": "Image path, must be .bin file in assets/ directory"
            },
            "opacity": {
              "type": "number",
              "minimum": 0,
              "maximum": 255,
              "default": 255,
              "description": "Image opacity (0-255)"
            },
            "rotation": {
              "type": "number",
              "minimum": 0,
              "maximum": 360,
              "description": "Rotation angle in degrees"
            },
            "scaleX": {
              "type": "number",
              "exclusiveMinimum": 0,
              "default": 1.0,
              "description": "Horizontal scale factor"
            },
            "scaleY": {
              "type": "number",
              "exclusiveMinimum": 0,
              "default": 1.0,
              "description": "Vertical scale factor"
            },
            "focusX": {
              "type": "number",
              "description": "Transform origin X coordinate"
            },
            "focusY": {
              "type": "number",
              "description": "Transform origin Y coordinate"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    
    "hg_view": {
      "allOf": [
        {
          "$ref": "#/definitions/component_base"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "pattern": "^view_[a-z0-9_]+$",
              "description": "View ID must start with 'view_'"
            },
            "residentMemory": {
              "type": "string",
              "enum": ["true", "false"],
              "description": "Keep in memory when switching views"
            },
            "opacity": {
              "type": "number",
              "minimum": 0,
              "maximum": 255,
              "default": 255,
              "description": "View opacity (0-255)"
            },
            "backgroundColor": {
              "type": "string",
              "pattern": "^#([0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})$",
              "description": "Background color in hex format"
            },
            "children": {
              "type": "array",
              "items": {
                "oneOf": [
                  { "$ref": "#/definitions/hg_button" },
                  { "$ref": "#/definitions/hg_label" },
                  { "$ref": "#/definitions/hg_image" },
                  { "$ref": "#/definitions/hg_view" }
                ]
              },
              "description": "Child components (can be nested)"
            }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
